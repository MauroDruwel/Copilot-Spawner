:root { --color: 0; }
* { box-sizing: border-box; }
body {
  margin: 0;
  font-family: "Quicksand", "Segoe UI", sans-serif;
  font-weight: 700;
  background: hsl(var(--color), 90%, 1%);
  color: hsl(var(--color), 95%, 93%);
  user-select: none;
  -webkit-tap-highlight-color: transparent;
  transition: opacity .5s, background .4s, color .4s;
}
.screen { min-height: 100vh; }
.wrapper {
  width: calc(100% - 24px);
  max-width: 980px;
  margin: 0 auto;
  padding-bottom: 40px;
}
.hero {
  text-align: center;
  padding: 68px 8px 24px;
}
.hero h1 {
  margin: 0;
  font-size: 64px;
  letter-spacing: -1px;
}
.hero p {
  margin: 6px 0 0;
  opacity: 0.66;
}
.panel {
  background: hsl(var(--color), 13%, 6%);
  border-radius: 26px;
  padding: 14px;
  margin: 10px 4px;
  box-shadow: inset 0 0 0 1px hsl(var(--color), 12%, 10%);
}
.panel-header {
  display: flex;
  align-items: center;
  margin: 0 4px 12px;
}
.panel-header h2 {
  font-size: 24px;
  margin: 0;
}
.panel-header button {
  margin-left: auto;
}
.path-pill {
  margin: 0 4px 10px;
  padding: 10px 12px;
  border-radius: 14px;
  font-size: 12px;
  opacity: 0.75;
  background: hsl(var(--color), 14%, 9%);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.action-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin: 0 4px 10px;
}
button, input[type="text"], .toggle {
  border: none;
  border-radius: 14px;
  background: hsl(var(--color), 15%, 10%);
  color: inherit;
  font-family: inherit;
  font-weight: 700;
}
button {
  padding: 10px 14px;
  cursor: pointer;
}
button:hover { background: hsl(var(--color), 14%, 14%); }
button.ghost { background: hsl(var(--color), 14%, 8%); }
button.ghost:hover { background: hsl(var(--color), 14%, 12%); }
input[type="text"] {
  outline: none;
  padding: 10px 12px;
  min-width: 200px;
}
.toggle {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 8px 10px;
  font-size: 12px;
}
.list { padding: 2px; }
.item {
  margin: 8px 2px;
  padding: 14px;
  border-radius: 18px;
  background: hsl(var(--color), 14%, 8%);
  display: flex;
  align-items: flex-start;
  gap: 12px;
}
.item .name { font-size: 16px; }
.item .meta { font-size: 12px; opacity: 0.66; margin-top: 3px; }
.item .right {
  margin-left: auto;
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  justify-content: flex-end;
}
.inline-actions {
  display: inline-flex;
  align-items: center;
  gap: 6px;
}
.badge {
  display: inline-block;
  margin-top: 6px;
  font-size: 12px;
  border-radius: 999px;
  padding: 4px 9px;
  background: hsl(var(--color), 14%, 13%);
}
.status-running { color: #8ff7c0; }
.status-failed { color: #ff9191; }
.status-stopped, .status-stopping { color: #ffd788; }
.session-log {
  margin-top: 10px;
  width: 100%;
  max-height: 220px;
  overflow: auto;
  border-radius: 12px;
  background: hsl(var(--color), 14%, 5%);
  color: #d4d7df;
  font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  font-size: 12px;
  line-height: 1.35;
  padding: 10px;
}
.flash {
  margin: 0 4px 10px;
  padding: 10px 12px;
  border-radius: 12px;
  background: hsl(var(--color), 14%, 9%);
  min-height: 34px;
  font-size: 12px;
  display: flex;
  align-items: center;
}
.flash.ok { color: #8ff7c0; }
.flash.error { color: #ff9f9f; }

.center {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.themes {
  margin: 8px 4px;
  display: flex;
  align-items: center;
  width: 100%;
}
.themes .theme {
  width: 50%;
  cursor: pointer;
  margin: 8px;
  padding: 4px 14px;
  background: #111;
  border-radius: 30px;
  border: 4px solid #0000;
  transition: all .2s;
}
.themes .theme.selected {
  border-color: hsl(var(--color), 90%, 75%);
}
.theme .preview .box {
  background: #222;
  border-radius: 16px;
  margin: 12px 0;
  height: 36px;
}
.theme.light {
  background: #EEE;
}
.theme.light .preview .box {
  background: #DDD;
}

.accents {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  max-width: 480px;
  padding: 8px 12px 12px;
}
.accents i {
  height: 32px;
  width: 32px;
  border-radius: 48px;
  cursor: pointer;
  margin: 8px 4px;
  overflow: hidden;
  position: relative;
  background: hsl(var(--color), var(--saturation, 100%), 50%);
  transition: all .2s;
}
.accents i::after {
  content: "✓";
  position: absolute;
  top: 100%;
  left: 50%;
  transform: translate(-50%, -50%);
  opacity: 0;
  transition: all .2s;
}
.accents .selected {
  width: 60px;
}
.accents .selected::after {
  top: 50%;
  opacity: 1;
  color: hsl(var(--color), 20%, 20%);
}

.red { --color: 0; }
.orange { --color: 24; }
.yellow { --color: 45; }
.green { --color: 90; }
.lightblue { --color: 210; }
.blue { --color: 240; }
.purple { --color: 270; }
.pink { --color: 320; }

body.light {
  background: hsl(var(--color), 5%, 92%);
  color: hsl(var(--color), 6%, 15%);
}
body.light .title-main div {
  color: hsl(var(--color), 100%, 25%);
}
body.light .panel {
  background: hsl(var(--color), 12%, 84%);
  box-shadow: inset 0 0 0 1px hsl(var(--color), 12%, 77%);
}
body.light .path-pill,
body.light .flash {
  background: hsl(var(--color), 12%, 80%);
}
body.light button,
body.light input[type="text"],
body.light .toggle {
  background: hsl(var(--color), 15%, 83%);
}
body.light button:hover {
  background: hsl(var(--color), 15%, 77%);
}
body.light button.ghost {
  background: hsl(var(--color), 15%, 79%);
}
body.light button.ghost:hover {
  background: hsl(var(--color), 15%, 73%);
}
body.light .item {
  background: hsl(var(--color), 12%, 84%);
}
body.light .badge {
  background: hsl(var(--color), 15%, 75%);
}
body.light .session-log {
  background: hsl(var(--color), 15%, 80%);
  color: hsl(var(--color), 12%, 14%);
}
body.light .themes .theme.selected {
  border-color: hsl(var(--color), 80%, 25%);
}
