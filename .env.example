# Copy to .env and fill in values, or export these directly in your shell /
# systemd unit. The app reads them via os.environ.

# REQUIRED for any real deployment. If unset, a random password is printed on
# startup and rotates every restart — fine for local tinkering, not for prod.
COPILOT_SPAWNER_PASSWORD=change-me

# HMAC key for the session cookie. If unset, a random key is generated on
# startup, invalidating all existing cookies whenever the process restarts.
COPILOT_SPAWNER_SECRET=replace-with-long-random-hex

# Network binding. Keep 127.0.0.1 and front with Cloudflare Tunnel / nginx /
# Caddy for anything public.
COPILOT_SPAWNER_HOST=127.0.0.1
COPILOT_SPAWNER_PORT=8765

# How long session cookies are valid, in seconds. Default is 7 days.
COPILOT_SPAWNER_SESSION_TTL=604800

# auto | true | false  — whether to mark cookies Secure. auto detects HTTPS
# from X-Forwarded-Proto.
COPILOT_SPAWNER_COOKIE_SECURE=auto

# Max bytes of PTY output retained in memory per session (the tail is kept).
COPILOT_SPAWNER_MAX_LOG=524288

# Root directory exposed by the explorer.
COPILOT_WORKSPACE=./workspace

# Path to the Copilot CLI binary. Override for testing (e.g. /bin/bash).
COPILOT_BIN=copilot

# Required for the Contributors feature. A fine-grained PAT with
# "Administration: write" on the target repo(s) works.
GITHUB_TOKEN=
